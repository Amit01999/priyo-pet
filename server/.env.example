# Server
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:8080

# MongoDB (local dev: mongodb://127.0.0.1:27017/priyopet_appointments, or use a free MongoDB Atlas cluster)
MONGODB_URI=mongodb://127.0.0.1:27017/priyopet_appointments

# Auth
JWT_ACCESS_SECRET=change-this-to-a-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN_DAYS=7
COOKIE_DOMAIN=localhost

# First admin account (used by `npm run seed:admin`, only runs if no admin exists yet)
SEED_ADMIN_NAME=Admin
SEED_ADMIN_EMAIL=admin@priyopet.com
SEED_ADMIN_PASSWORD=change-this-password

# Transactional email (Nodemailer). Optional — if any of these are missing, the server falls
# back to console-only notifications instead of failing to boot.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your-email@gmail.com
MAIL_PASS=your-gmail-app-password
MAIL_FROM="Your Clinic <your-email@gmail.com>"

# bKash "Send Money" number shown on the public payment step
BKASH_MERCHANT_NUMBER=01700000000
